#!/bin/sh

# Detect if being run as a user service, which implies external session management,
# exec compositor directly
NIRI_BIN="${NIRI_BIN:-niri-cidre}"
NIRI_CONFIG="${NIRI_CONFIG:-$HOME/.config/niri/config.cidre.kdl}"

run_niri() {
    if [ -f "$NIRI_CONFIG" ]; then
        exec "$NIRI_BIN" --session --config "$NIRI_CONFIG" "$@"
    fi

    exec "$NIRI_BIN" --session "$@"
}

if [ -n "${MANAGERPID:-}" ] && [ "${SYSTEMD_EXEC_PID:-}" = "$$" ]; then
    case "$(ps -p "$MANAGERPID" -o cmd=)" in
    *systemd*--user*)
        run_niri
        ;;
    esac
fi

if [ -n "$SHELL" ] &&
   grep -q "$SHELL" /etc/shells &&
   ! (echo "$SHELL" | grep -q "false") &&
   ! (echo "$SHELL" | grep -q "nologin"); then
  if [ "$1" != '-l' ]; then
    exec bash -c "exec -l '$SHELL' -c 'exec $0 -l $*'"
  else
    shift
  fi
fi

# Try to detect the service manager that is being used
if hash systemctl >/dev/null 2>&1; then
    if systemctl --user -q is-active cidre.service; then
      echo 'A Cidre session is already running.'
      exit 1
    fi

    systemctl --user reset-failed
    systemctl --user import-environment

    if hash dbus-update-activation-environment 2>/dev/null; then
        dbus-update-activation-environment --all
    fi

    systemctl --user --wait start cidre.service
    systemctl --user start --job-mode=replace-irreversibly cidre-shutdown.target
    systemctl --user unset-environment WAYLAND_DISPLAY DISPLAY XDG_SESSION_TYPE XDG_CURRENT_DESKTOP NIRI_SOCKET
elif hash dinitctl >/dev/null 2>&1; then
    run_niri "$@"
else
    run_niri "$@"
fi
